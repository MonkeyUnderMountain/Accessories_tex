{
  "custom_macros": {
    "kk": {
      "xelatex": "\\mathbf{k}",
      "pdflatex": "\\mathbf{k}",
      "typst": "math.bold(\"k\")"
    },
    "kkk": {
      "xelatex": "\\mathbb{k}",
      "pdflatex": "\\mathbbm{k}",
      "typst": "math.bb(\"k\")"
    },
    "rkk": {
      "xelatex": "\\kappa",
      "pdflatex": "\\kappa",
      "typst": "math.kappa"
    },
    "fkk": {
      "xelatex": "\\mathscr{K}",
      "pdflatex": "\\mathscr{K}",
      "typst": "math.scr(\"K\")"
    },
    "im": {
      "xelatex": "\\sqrt{-1}",
      "pdflatex": "\\sqrt{-1}",
      "typst": "math.sqrt(\"-1\")"
    },
    "ten": {
      "xelatex": "\\otimes",
      "pdflatex": "\\otimes",
      "typst": "math.times.o"
    },
    "tensor": {
      "xelatex": "\\otimes",
      "pdflatex": "\\otimes",
      "typst": "math.times.o"
    },
    "injmap": {
      "xelatex": "\\hookrightarrow",
      "pdflatex": "\\hookrightarrow",
      "typst": "math.arrow.r.hook"
    },
    "surjmap": {
      "xelatex": "\\twoheadrightarrow",
      "pdflatex": "\\twoheadrightarrow",
      "typst": "math.arrow.r.twohead"
    },
    "ratmap": {
      "xelatex": "\\dashrightarrow",
      "pdflatex": "\\dashrightarrow",
      "typst": "math.arrow.r.dashed"
    },
    "colim": {
      "xelatex": "\\operatorname{colim}",
      "pdflatex": "\\operatorname{colim}",
      "typst": "math.op.colim"
    },
    "acts": {
      "xelatex": "\\curvearrowright",
      "pdflatex": "\\curvearrowright",
      "typst": "math.arrow.r.curve"
    },
    "isom": {
      "xelatex": "\\xrightarrow{\\equiv}",
      "pdflatex": "\\xrightarrow{\\equiv}",
      "typst": "math.tilde.equiv"
    }
  },
